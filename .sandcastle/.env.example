# Claude Code OAuth token
# Export from your local Claude Code setup if needed:
#   claude setup-token
CLAUDE_CODE_OAUTH_TOKEN=
# Codex subscription auth for the review agent. This is not an API key.
# Run `codex login --device-auth` locally, then point this at the Codex home
# directory that contains auth.json. Sandcastle mounts it read-only and copies
# auth.json into each sandbox before running Codex.
SANDCASTLE_CODEX_HOME=~/.codex
# GitHub personal access token — Sandcastle uses it to read issues, push
# branches, create/update PRs, comment on PRs, and squash-merge approved PRs.
# Create a fine-grained token: https://github.com/settings/personal-access-tokens/new
# Required repository permissions:
# - Metadata: Read
# - Contents: Read and write
# - Issues: Read and write
# - Pull requests: Read and write
GH_TOKEN=
